@page "/"
@rendermode InteractiveServer

<PageTitle>Joc</PageTitle>

<div class="simon-page">
    <div class="simon-shell">
        <div class="simon-top-bar">
            <div class="simon-header">
                <h1>Color Grid Memory</h1>
                <p>Priveste butonul aprins si ghiceste-l corect.</p>
            </div>
            <button class="simon-start-btn simon-start-btn-top" @onclick="StartNewGame">
                Start joc nou
            </button>
        </div>

        <div class="simon-status-panel">
            <p class="simon-status-message">@statusMessage</p>
            <div class="simon-status-cards">
                <p class="simon-level-pill">Scor: <strong>@score</strong></p>
                <p class="simon-speed-pill">Speed: <strong>@GetHighlightDurationMs() ms</strong></p>
            </div>
        </div>

        <div class="simon-grid-wrapper">
            <div class="simon-grid simon-grid-25">
                @for (var i = 0; i < TotalButtons; i++)
                {
                    var buttonIndex = i;
                    <button class="@GetCardClass(buttonIndex)"
                            style="@GetCardStyle(buttonIndex)"
                            disabled="@(!canPlayerClick || isPlayingSequence)"
                            @onclick="() => OnPlayerClick(buttonIndex)">
                        <span class="simon-card-number">@(buttonIndex + 1)</span>
                    </button>
                }
            </div>
        </div>
    </div>
</div>

@if (showIntroMessage)
{
    <div class="simon-overlay" role="dialog" aria-modal="true" aria-label="Instructiuni joc">
        <div class="simon-overlay-content simon-intro-content">
            <h2>Instructiuni rapide</h2>
            <p>1. Apasa <strong>Start joc nou</strong>.</p>
            <p>2. Se aprinde un singur buton in grila 5x5.</p>
            <p>3. Apasa butonul corect pentru a creste scorul.</p>
            <p>4. Daca gresesti, jocul se reseteaza.</p>
            <button class="simon-start-btn simon-intro-close-btn" @onclick="DismissIntroMessage">Am inteles</button>
        </div>
    </div>
}

@if (showCenterMessage)
{
    <div class="simon-overlay" role="alert" aria-live="assertive">
        <div class="simon-overlay-content">@centerMessage</div>
    </div>
}

@code {
    private readonly Random random = new();
    private const int TotalButtons = 25;
    private const int InitialHighlightDurationMs = 1000;
    private const int MinimumHighlightDurationMs = 120;

    private int? highlightedButton;
    private int? selectedButton;
    private int targetButton = -1;
    private int score;
    private int gameSessionId;
    private bool isPlayingSequence;
    private bool canPlayerClick;
    private string statusMessage = "Apasa Start joc nou pentru a incepe.";
    private bool showIntroMessage = true;
    private bool showCenterMessage;
    private string centerMessage = string.Empty;

    private async Task StartNewGame()
    {
        var sessionId = BeginNewSession();
        score = 0;
        targetButton = -1;
        statusMessage = "Pregateste-te! Memorizeaza butonul aprins.";
        canPlayerClick = false;
        highlightedButton = null;
        selectedButton = null;
        showCenterMessage = false;
        centerMessage = string.Empty;
        await StartNextRound(sessionId, true);
    }

    private async Task StartNextRound(int sessionId, bool isFirstRound = false)
    {
        if (IsStaleSession(sessionId))
        {
            return;
        }

        targetButton = random.Next(0, TotalButtons);
        canPlayerClick = false;
        statusMessage = isFirstRound
            ? "Prima runda: priveste cu atentie."
            : "Runda noua: priveste butonul aprins.";

        await PlayTargetButton(sessionId);

        if (IsStaleSession(sessionId))
        {
            return;
        }

        statusMessage = "Randul tau: ghiceste butonul.";
        canPlayerClick = true;
    }

    private async Task PlayTargetButton(int sessionId)
    {
        if (IsStaleSession(sessionId))
        {
            return;
        }

        var highlightDurationMs = GetHighlightDurationMs();
        isPlayingSequence = true;
        highlightedButton = targetButton;
        StateHasChanged();
        await Task.Delay(highlightDurationMs);

        if (IsStaleSession(sessionId))
        {
            highlightedButton = null;
            isPlayingSequence = false;
            return;
        }

        highlightedButton = null;
        StateHasChanged();
        await Task.Delay(220);
        isPlayingSequence = false;
    }

    private async Task OnPlayerClick(int buttonIndex)
    {
        var sessionId = gameSessionId;
        if (!canPlayerClick || IsStaleSession(sessionId))
        {
            return;
        }

        selectedButton = buttonIndex;
        _ = ClearSelectedButtonAsync(buttonIndex, sessionId);

        if (buttonIndex != targetButton)
        {
            var reachedScore = score;
            statusMessage = $"Ai gresit. Scor final: {reachedScore}.";
            canPlayerClick = false;

            await ShowCenterMessageAsync("Ai gresit! Iti arat butonul corect.", 1300, sessionId);
            if (IsStaleSession(sessionId))
            {
                return;
            }

            statusMessage = "Butonul corect este afisat acum.";
            await PlayTargetButton(sessionId);
            if (IsStaleSession(sessionId))
            {
                return;
            }

            await ShowCenterMessageAsync("Incepe jocul!", 2000, sessionId);
            if (IsStaleSession(sessionId))
            {
                return;
            }

            await StartNewGame();
            return;
        }

        score++;
        statusMessage = "Corect! Urmeaza urmatorul buton.";
        canPlayerClick = false;
        await Task.Delay(650);

        if (IsStaleSession(sessionId))
        {
            return;
        }

        await StartNextRound(sessionId);
    }

    private string GetCardClass(int buttonIndex)
    {
        var active = highlightedButton == buttonIndex ? " active" : string.Empty;
        var selected = selectedButton == buttonIndex ? " selected" : string.Empty;
        return $"simon-card simon-{buttonIndex}{active}{selected}";
    }

    private string GetCardStyle(int buttonIndex)
    {
        var hue = (buttonIndex * 360 / TotalButtons) % 360;
        return $"background-color: hsl({hue} 72% 52%);";
    }

    private async Task ClearSelectedButtonAsync(int buttonIndex, int sessionId)
    {
        await InvokeAsync(StateHasChanged);
        await Task.Delay(180);

        if (IsStaleSession(sessionId))
        {
            return;
        }

        if (selectedButton == buttonIndex)
        {
            selectedButton = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void DismissIntroMessage()
    {
        showIntroMessage = false;
    }

    private async Task ShowCenterMessageAsync(string message, int durationMs, int sessionId)
    {
        if (IsStaleSession(sessionId))
        {
            return;
        }

        centerMessage = message;
        showCenterMessage = true;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(durationMs);

        if (IsStaleSession(sessionId))
        {
            return;
        }

        showCenterMessage = false;
        await InvokeAsync(StateHasChanged);
    }

    private int BeginNewSession()
    {
        gameSessionId++;
        return gameSessionId;
    }

    private bool IsStaleSession(int sessionId)
    {
        return sessionId != gameSessionId;
    }

    private int GetHighlightDurationMs()
    {
        var duration = InitialHighlightDurationMs;

        for (var i = 0; i < score; i++)
        {
            if (duration > 500)
            {
                duration -= 50;
            }
            else if (duration > 300)
            {
                duration -= 25;
            }
            else
            {
                duration -= 15;
            }
        }

        return Math.Max(MinimumHighlightDurationMs, duration);
    }
}
