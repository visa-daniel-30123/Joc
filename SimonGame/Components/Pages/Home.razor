@page "/"
@rendermode InteractiveServer
@implements IDisposable
@using SimonGame.Services
@using System.Globalization
@using System.Linq
@inject GameSessionState GameState

<PageTitle>FlashFocus</PageTitle>

<div class="simon-page">
    <div class="simon-shell">
        <div class="simon-top-bar">
            <button class="simon-start-btn simon-start-btn-top" @onclick="StartNewGame">
                Start joc nou
            </button>
        </div>

        <div class="simon-status-panel">
            <p class="simon-status-message">@statusMessage</p>
            <div class="simon-status-cards">
                <p class="simon-phase-pill @GetPhaseClass()">Faza: <strong>@GetPhaseLabel()</strong></p>
                <p class="simon-level-pill">Scor baza: <strong>@score</strong></p>
                <p class="simon-speed-pill">Bonus: <strong>@bonusTotal.ToString("0.00", CultureInfo.InvariantCulture)</strong></p>
                <p class="simon-level-pill">Total: <strong>@GetTotalScore().ToString("0.00", CultureInfo.InvariantCulture)</strong></p>
                <p class="simon-speed-pill">Speed: <strong>@GetHighlightDurationMs() ms</strong></p>
                <p class="simon-speed-pill">Mode: <strong>@($"{gridSize}x{gridSize}")</strong></p>
            </div>
        </div>

        <div class="simon-grid-wrapper">
            <div class="simon-grid" style="@GetGridStyle()">
                @for (var i = 0; i < TotalButtons; i++)
                {
                    var buttonIndex = i;
                    <button class="@GetCardClass(buttonIndex)"
                            style="@GetCardStyle(buttonIndex)"
                            disabled="@(!canPlayerClick || isPlayingSequence)"
                            @onclick="() => OnPlayerClick(buttonIndex)">
                    </button>
                }
            </div>
        </div>

        <div class="simon-stats-panel">
            <h3>Statistici runde (Normal)</h3>
            <div class="simon-stats-table-wrap">
                <table class="simon-stats-table">
                    <thead>
                        <tr>
                            <th>Ora</th>
                            <th>Runda</th>
                            <th>Raspuns</th>
                            <th>Timp total</th>
                            <th>Scor</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in GetRecentStats())
                        {
                            <tr>
                                <td>@row.CreatedAt.ToLocalTime().ToString("HH:mm:ss", CultureInfo.InvariantCulture)</td>
                                <td>@row.Round</td>
                                <td>@FormatMs(row.ResponseMs)</td>
                                <td>@FormatMs(row.ElapsedMs)</td>
                                <td>@row.Score</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@if (showIntroMessage)
{
    <div class="simon-overlay" role="dialog" aria-modal="true" aria-label="Instructiuni joc">
        <div class="simon-overlay-content simon-intro-content">
            <h2>Instructiuni rapide</h2>
            <p>1. Apasa <strong>Start joc nou</strong>.</p>
            <p>2. Alege modul 4x4, 5x5 sau 6x6 din bara de sus.</p>
            <p>3. Se aprinde un singur buton pe grila aleasa.</p>
            <p>4. Apasa butonul corect pentru a creste scorul.</p>
            <p>5. Daca gresesti, jocul se reseteaza.</p>
            <button class="simon-start-btn simon-intro-close-btn" @onclick="DismissIntroMessage">Am inteles</button>
        </div>
    </div>
}

@if (showCenterMessage)
{
    <div class="simon-overlay" role="alert" aria-live="assertive">
        <div class="simon-overlay-content">
            <p class="simon-center-message-text">@centerMessage</p>
            @if (showCenterActionButton)
            {
                <div class="simon-center-actions">
                    <button class="simon-start-btn simon-center-action-btn" @onclick="OnCenterActionClick">
                        Incepe jocul
                    </button>
                    <button class="simon-secondary-btn simon-center-action-btn" @onclick="OnCenterExitClick">
                        Iesi
                    </button>
                </div>
            }
        </div>
    </div>
}

@if (showRecordCelebration)
{
    <div class="simon-overlay" role="alert" aria-live="assertive">
        <div class="simon-overlay-content simon-record-overlay">
            <div class="bomb-wrap" aria-hidden="true">
                <div class="bomb-body"></div>
                <div class="bomb-fuse"></div>
                <div class="bomb-spark"></div>
                <div class="bomb-ring bomb-ring-1"></div>
                <div class="bomb-ring bomb-ring-2"></div>
                <div class="bomb-ring bomb-ring-3"></div>
            </div>
            <p class="simon-record-title">Felicitari, ai batut recordul!</p>
        </div>
    </div>
}

@code {
    private readonly Random random = new();
    private const int InitialHighlightDurationMs = 1000;
    private const int MinimumHighlightDurationMs = 120;

    private int gridSize = 5;
    private GameColorMode colorMode = GameColorMode.Random;
    private int monoHue = 212;
    private int? highlightedButton;
    private int? selectedButton;
    private int targetButton = -1;
    private int score;
    private double bonusTotal;
    private DateTimeOffset runStartedAt = DateTimeOffset.UtcNow;
    private DateTimeOffset roundInputStartedAt = DateTimeOffset.UtcNow;
    private int runSuccessfulResponseTotalMs;
    private int runSuccessfulResponseCount;
    private int runAllResponseTotalMs;
    private int runAllResponseCount;
    private int gameSessionId;
    private bool isPlayingSequence;
    private bool canPlayerClick;
    private string statusMessage = "Apasa Start joc nou pentru a incepe.";
    private bool showIntroMessage = true;
    private bool showCenterMessage;
    private bool showCenterActionButton;
    private bool showRecordCelebration;
    private string centerMessage = string.Empty;
    private TaskCompletionSource<bool>? centerActionCompletion;
    private int runStartingHighScore;
    private int TotalButtons => gridSize * gridSize;

    protected override void OnInitialized()
    {
        GameState.SetActiveGameType(GameType.Normal);
        gridSize = GameState.GridSize;
        colorMode = GameState.ColorMode;
        monoHue = GameState.MonoHue;
        GameState.Changed += OnGameStateChanged;
    }

    public void Dispose()
    {
        GameState.Changed -= OnGameStateChanged;
    }

    private async Task StartNewGame()
    {
        var sessionId = BeginNewSession();
        score = 0;
        bonusTotal = 0;
        runStartingHighScore = GameState.HighScore;
        runStartedAt = DateTimeOffset.UtcNow;
        runSuccessfulResponseTotalMs = 0;
        runSuccessfulResponseCount = 0;
        runAllResponseTotalMs = 0;
        runAllResponseCount = 0;
        targetButton = -1;
        statusMessage = $"Pregateste-te! Memorizeaza butonul aprins ({gridSize}x{gridSize}).";
        canPlayerClick = false;
        highlightedButton = null;
        selectedButton = null;
        showCenterMessage = false;
        showCenterActionButton = false;
        showRecordCelebration = false;
        centerMessage = string.Empty;
        centerActionCompletion?.TrySetCanceled();
        centerActionCompletion = null;
        await StartNextRound(sessionId, true);
    }

    private async Task StartNextRound(int sessionId, bool isFirstRound = false)
    {
        if (IsStaleSession(sessionId))
        {
            return;
        }

        targetButton = random.Next(0, TotalButtons);
        canPlayerClick = false;
        statusMessage = isFirstRound
            ? "Prima runda: priveste cu atentie."
            : "Runda noua: priveste butonul aprins.";

        await PlayTargetButton(sessionId);

        if (IsStaleSession(sessionId))
        {
            return;
        }

        statusMessage = "Randul tau: ghiceste butonul.";
        canPlayerClick = true;
        roundInputStartedAt = DateTimeOffset.UtcNow;
    }

    private async Task PlayTargetButton(int sessionId)
    {
        if (IsStaleSession(sessionId))
        {
            return;
        }

        var highlightDurationMs = GetHighlightDurationMs();
        isPlayingSequence = true;
        highlightedButton = targetButton;
        StateHasChanged();
        await Task.Delay(highlightDurationMs);

        if (IsStaleSession(sessionId))
        {
            highlightedButton = null;
            isPlayingSequence = false;
            return;
        }

        highlightedButton = null;
        StateHasChanged();
        await Task.Delay(220);
        isPlayingSequence = false;
    }

    private async Task OnPlayerClick(int buttonIndex)
    {
        var sessionId = gameSessionId;
        if (!canPlayerClick || IsStaleSession(sessionId))
        {
            return;
        }

        selectedButton = buttonIndex;
        _ = ClearSelectedButtonAsync(buttonIndex, sessionId);
        var roundNumber = score + 1;
        var responseMs = GetDurationMs(roundInputStartedAt);
        var elapsedMs = GetDurationMs(runStartedAt);
        var averageForBonusMs = (runAllResponseTotalMs + responseMs) / (double)(runAllResponseCount + 1);
        var speedMultiplier = GetSpeedMultiplier(averageForBonusMs);
        var roundBonus = (roundNumber / 10.0) * speedMultiplier;
        var averageResponseMs = runSuccessfulResponseCount > 0
            ? runSuccessfulResponseTotalMs / runSuccessfulResponseCount
            : responseMs;

        if (buttonIndex != targetButton)
        {
            var reachedScore = score;
            statusMessage = $"Ai gresit. Scor final: {reachedScore} + bonus {bonusTotal:0.00} = {GetTotalScore():0.00}.";
            canPlayerClick = false;
            GameState.AddStat(new GameStatEntry(
                DateTimeOffset.UtcNow,
                GameType.Normal,
                $"{gridSize}x{gridSize}",
                roundNumber,
                false,
                averageResponseMs,
                elapsedMs,
                GetTotalScoreRounded()));
            runAllResponseTotalMs += responseMs;
            runAllResponseCount++;

            await ShowCenterMessageAsync("Ai gresit! Iti arat butonul corect.", 1300, sessionId);
            if (IsStaleSession(sessionId))
            {
                return;
            }

            statusMessage = "Butonul corect este afisat acum.";
            await PlayTargetButton(sessionId);
            if (IsStaleSession(sessionId))
            {
                return;
            }

            if (runStartingHighScore > 0 && GetTotalScoreRounded() > runStartingHighScore)
            {
                await ShowRecordCelebrationAsync(sessionId);
                if (IsStaleSession(sessionId))
                {
                    return;
                }
            }

            var shouldRestart = await WaitForCenterActionAsync("Apasa butonul ca sa inceapa jocul.", sessionId);
            if (IsStaleSession(sessionId))
            {
                return;
            }

            if (shouldRestart)
            {
                await StartNewGame();
            }
            else
            {
                statusMessage = "Joc oprit. Apasa Start joc nou cand vrei sa continui.";
            }
            return;
        }

        score++;
        bonusTotal += roundBonus;
        runSuccessfulResponseTotalMs += responseMs;
        runSuccessfulResponseCount++;
        runAllResponseTotalMs += responseMs;
        runAllResponseCount++;
        GameState.RegisterScore(GetTotalScoreRounded(), GameType.Normal);
        statusMessage = $"Corect! Bonus runda +{roundBonus:0.00} (x{speedMultiplier}, medie {averageForBonusMs / 1000.0:0.00}s, cumulat: {bonusTotal:0.00}).";
        canPlayerClick = false;
        await Task.Delay(650);

        if (IsStaleSession(sessionId))
        {
            return;
        }

        await StartNextRound(sessionId);
    }

    private string GetCardClass(int buttonIndex)
    {
        var active = highlightedButton == buttonIndex ? " active" : string.Empty;
        var selected = selectedButton == buttonIndex ? " selected" : string.Empty;
        return $"simon-card simon-{buttonIndex}{active}{selected}";
    }

    private string GetCardStyle(int buttonIndex)
    {
        if (colorMode == GameColorMode.Mono)
        {
            // Keep the same base hue and only nudge lightness/saturation a bit.
            var variation = (buttonIndex % 9) - 4;
            var saturation = 58 + variation;
            var topLightness = 57 + variation;
            var bottomLightness = 47 + variation;
            return $"background: linear-gradient(145deg, hsl({monoHue} {saturation}% {topLightness}%) 0%, hsl({monoHue} {Math.Max(45, saturation - 6)}% {bottomLightness}%) 100%);";
        }

        var hue = (buttonIndex * 360 / TotalButtons) % 360;
        return $"background-color: hsl({hue} 72% 52%);";
    }

    private string GetGridStyle()
    {
        return $"grid-template-columns: repeat({gridSize}, var(--simon-cell-size)); --simon-cell-size: {GetCellSizePx()}px;";
    }

    private async Task ClearSelectedButtonAsync(int buttonIndex, int sessionId)
    {
        await InvokeAsync(StateHasChanged);
        await Task.Delay(180);

        if (IsStaleSession(sessionId))
        {
            return;
        }

        if (selectedButton == buttonIndex)
        {
            selectedButton = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void DismissIntroMessage()
    {
        showIntroMessage = false;
    }

    private async Task ShowCenterMessageAsync(string message, int durationMs, int sessionId)
    {
        if (IsStaleSession(sessionId))
        {
            return;
        }

        centerMessage = message;
        showCenterMessage = true;
        showCenterActionButton = false;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(durationMs);

        if (IsStaleSession(sessionId))
        {
            return;
        }

        showCenterMessage = false;
        showCenterActionButton = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task ShowRecordCelebrationAsync(int sessionId)
    {
        if (IsStaleSession(sessionId))
        {
            return;
        }

        showRecordCelebration = true;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(8000);

        if (IsStaleSession(sessionId))
        {
            return;
        }

        showRecordCelebration = false;
        await InvokeAsync(StateHasChanged);
    }

    private int BeginNewSession()
    {
        centerActionCompletion?.TrySetCanceled();
        centerActionCompletion = null;
        gameSessionId++;
        return gameSessionId;
    }

    private bool IsStaleSession(int sessionId)
    {
        return sessionId != gameSessionId;
    }

    private int GetHighlightDurationMs()
    {
        var duration = InitialHighlightDurationMs;

        for (var i = 0; i < score; i++)
        {
            if (duration > 500)
            {
                duration -= 50;
            }
            else if (duration > 300)
            {
                duration -= 25;
            }
            else
            {
                duration -= 15;
            }
        }

        return Math.Max(MinimumHighlightDurationMs, duration);
    }

    private int GetCellSizePx()
    {
        return gridSize switch
        {
            4 => 86,
            5 => 72,
            6 => 60,
            _ => 72
        };
    }

    private async Task<bool> WaitForCenterActionAsync(string message, int sessionId)
    {
        if (IsStaleSession(sessionId))
        {
            return false;
        }

        centerActionCompletion?.TrySetCanceled();
        centerActionCompletion = new TaskCompletionSource<bool>(TaskCreationOptions.RunContinuationsAsynchronously);

        centerMessage = message;
        showCenterMessage = true;
        showCenterActionButton = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var accepted = await centerActionCompletion.Task;

            if (IsStaleSession(sessionId))
            {
                return false;
            }

            showCenterMessage = false;
            showCenterActionButton = false;
            centerActionCompletion = null;
            await InvokeAsync(StateHasChanged);
            return accepted;
        }
        catch (TaskCanceledException)
        {
            return false;
        }
    }

    private void OnCenterActionClick()
    {
        centerActionCompletion?.TrySetResult(true);
    }

    private void OnCenterExitClick()
    {
        centerActionCompletion?.TrySetResult(false);
    }

    private void OnGameStateChanged()
    {
        var selectedGridSize = GameState.GridSize;
        var selectedColorMode = GameState.ColorMode;
        var selectedMonoHue = GameState.MonoHue;

        if (selectedGridSize != gridSize || selectedColorMode != colorMode || selectedMonoHue != monoHue)
        {
            gridSize = selectedGridSize;
            colorMode = selectedColorMode;
            monoHue = selectedMonoHue;
            _ = InvokeAsync(ResetForSelectedOptionsAsync);
            return;
        }
    }

    private Task ResetForSelectedOptionsAsync()
    {
        BeginNewSession();
        score = 0;
        bonusTotal = 0;
        targetButton = -1;
        runSuccessfulResponseTotalMs = 0;
        runSuccessfulResponseCount = 0;
        runAllResponseTotalMs = 0;
        runAllResponseCount = 0;
        highlightedButton = null;
        selectedButton = null;
        canPlayerClick = false;
        isPlayingSequence = false;
        showCenterMessage = false;
        showCenterActionButton = false;
        showRecordCelebration = false;
        centerMessage = string.Empty;
        statusMessage = colorMode == GameColorMode.Mono
            ? $"Setari actualizate ({gridSize}x{gridSize}, Mono). Apasa Start joc nou."
            : $"Setari actualizate ({gridSize}x{gridSize}, Random). Apasa Start joc nou.";
        StateHasChanged();
        return Task.CompletedTask;
    }

    private string GetPhaseLabel()
    {
        if (isPlayingSequence)
        {
            return "Priveste";
        }

        if (canPlayerClick)
        {
            return "Apasa";
        }

        return "Pauza";
    }

    private string GetPhaseClass()
    {
        return isPlayingSequence ? "watch" : canPlayerClick ? "input" : "pause";
    }

    private double GetTotalScore()
    {
        return score + bonusTotal;
    }

    private int GetTotalScoreRounded()
    {
        return (int)Math.Round(GetTotalScore(), MidpointRounding.AwayFromZero);
    }

    private IReadOnlyList<GameStatEntry> GetRecentStats()
    {
        return GameState.GetStats(GameType.Normal).Take(12).ToList();
    }

    private static string FormatMs(int valueMs)
    {
        return $"{valueMs / 1000.0:0.00}s";
    }

    private static int GetDurationMs(DateTimeOffset from)
    {
        return (int)Math.Max(0, (DateTimeOffset.UtcNow - from).TotalMilliseconds);
    }

    private static int GetSpeedMultiplier(double averageResponseMs)
    {
        if (averageResponseMs < 200)
        {
            return 5;
        }

        if (averageResponseMs < 300)
        {
            return 4;
        }

        if (averageResponseMs < 500)
        {
            return 3;
        }

        if (averageResponseMs < 1000)
        {
            return 2;
        }

        return 1;
    }
}
