@inherits LayoutComponentBase
@implements IDisposable
@using SimonGame.Services
@inject GameSessionState GameState

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 main-top-row">
            <div class="main-mode-switch">
                <span class="main-mode-label">Mode:</span>
                @foreach (var size in GameSessionState.SupportedGridSizes)
                {
                    <button class="@GetModeButtonClass(size)" @onclick="() => SetGridSize(size)">
                        @($"{size}x{size}")
                    </button>
                }
            </div>
            <div class="main-mode-switch">
                <span class="main-mode-label">Color:</span>
                @foreach (var colorMode in GameSessionState.SupportedColorModes)
                {
                    <button class="@GetColorModeButtonClass(colorMode)" @onclick="() => SetColorMode(colorMode)">
                        @GetColorModeLabel(colorMode)
                    </button>
                }
            </div>
            @if (GameState.ColorMode == GameColorMode.Mono)
            {
                <div class="main-mode-switch">
                    <span class="main-mode-label">Mono hue:</span>
                    @foreach (var option in GameSessionState.SupportedMonoColors)
                    {
                        <button class="@GetMonoColorButtonClass(option.Hue)" @onclick="() => SetMonoHue(option.Hue)">
                            @option.Label
                        </button>
                    }
                </div>
            }
            <span class="main-high-score">High score @($"{GameState.GridSize}x{GameState.GridSize}"): @GameState.HighScore</span>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    protected override void OnInitialized()
    {
        GameState.Changed += OnGameStateChanged;
    }

    private void OnGameStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void SetGridSize(int size)
    {
        GameState.SetGridSize(size);
    }

    private void SetColorMode(GameColorMode colorMode)
    {
        GameState.SetColorMode(colorMode);
    }

    private string GetModeButtonClass(int size)
    {
        return size == GameState.GridSize ? "main-mode-btn active" : "main-mode-btn";
    }

    private string GetColorModeButtonClass(GameColorMode colorMode)
    {
        return colorMode == GameState.ColorMode ? "main-mode-btn active" : "main-mode-btn";
    }

    private string GetMonoColorButtonClass(int hue)
    {
        return hue == GameState.MonoHue ? "main-mode-btn active" : "main-mode-btn";
    }

    private static string GetColorModeLabel(GameColorMode colorMode)
    {
        return colorMode == GameColorMode.Mono ? "Mono" : "Random";
    }

    private void SetMonoHue(int hue)
    {
        GameState.SetMonoHue(hue);
    }

    public void Dispose()
    {
        GameState.Changed -= OnGameStateChanged;
    }
}

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
